# Copy to .env (or set in your shell / compose) and adjust.

# Postgres connection (SQLAlchemy + psycopg driver)
LAWTRACK_DATABASE_URL=postgresql+psycopg://lawtrack:lawtrack@localhost:5432/lawtrack

# CHANGE THIS in any real deployment — signs the login JWTs.
LAWTRACK_JWT_SECRET=change-me-to-a-long-random-string
LAWTRACK_ACCESS_TOKEN_EXPIRE_MINUTES=720

# Seed the demo dataset (policies + sample documents + demo/demo login) if the DB is empty.
LAWTRACK_SEED_ON_STARTUP=true

# Anthropic credentials for the live pipeline (real PDF analysis).
# Omit to run demo-only; an `ant auth login` profile also works.
# ANTHROPIC_API_KEY=sk-ant-...
